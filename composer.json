{
    "name": "latticedb/latticedb",
    "description": "PHP FFI wrapper for LatticeDB — embedded knowledge graph with vector search and full-text search",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "LatticeDB\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LatticeDB\\Tests\\": "tests/"
        }
    }
}
